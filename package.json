{
  "name": "realtime-asr",
  "version": "1.0.0",
  "private": true,
  "description": "Browser Realtime Speech Recognition SDK",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "demo": "pnpm --filter realtime-asr-vanilla-demo dev",
    "clean": "pnpm -r run clean",
    "lint": "eslint packages --ext .ts",
    "format": "prettier --write \"packages/**/*.ts\""
  },
  "keywords": [
    "asr",
    "speech-recognition",
    "realtime",
    "browser",
    "tencent",
    "audio"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
